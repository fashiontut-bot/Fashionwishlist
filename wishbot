from telegram.ext import ApplicationBuilder, CommandHandler, CallbackQueryHandler
import json, os
import config

wishlist_file = "wishlist.json"
user_links = {}

def load_wishlist(): 
    try: return json.load(open(wishlist_file))
    except: return {}

def save_wishlist(data):
    json.dump(data, open(wishlist_file, 'w'), ensure_ascii=False, indent=2)

async def button_save(update, context):
    query = update.callback_query
    idx = int(query.data.split('_')[1])
    name = config.links_list[idx][0]
    
    user_id = query.from_user.id
    user_links.setdefault(str(user_id), []).append(name)
    save_wishlist(user_links)
    
    await query.answer(f"✅ {name} в вишлист!")

async def show_wishlist(update, context):
    user_id = str(update.message.from_user.id)
    items = user_links.get(user_id, [])
    if items:
        text = "💖 " + "\n".join(f"• {item}" for item in items)
    else:
        text = "💔 Пусто"
    await update.message.reply_text(text)

def main():
    app = ApplicationBuilder().token("WISHLIST_TOKEN").build()
    app.add_handler(CallbackQueryHandler(button_save, pattern="^save_"))
    app.add_handler(CommandHandler("wishlist", show_wishlist))
    app.run_polling()

if __name__ == "__main__":
    main()
